PORT=5000
MONGODB_URI=mongodb://localhost:27017/smartrental
JWT_SECRET=your_super_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRES_IN=15m
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ESMS (SMS OTP)
ESMS_API_KEY=your_esms_api_key
ESMS_SECRET_KEY=your_esms_secret_key
ESMS_BRANDNAME=SmartRental

# Redis (optional — falls back to memory store if omitted)
REDIS_URL=redis://localhost:6379

# ─── PayOS ────────────────────────────────────────────────────────────────────
# Lấy tại: https://my.payos.vn → Tài khoản → Thông tin tích hợp
# Sandbox:    dùng khi NODE_ENV=development (test miễn phí, không cần KYC)
# Production: sau khi KYC + xác minh doanh nghiệp trên PayOS

PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# URL PayOS redirect sau khi thanh toán thành công / huỷ
# Production: phải là HTTPS, ví dụ https://smartrental.vn/payment/success
PAYOS_RETURN_URL=http://localhost:3000/payment/success
PAYOS_CANCEL_URL=http://localhost:3000/payment/cancel
